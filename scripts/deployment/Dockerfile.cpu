# CPU-only版本Docker镜像
FROM ubuntu:22.04

# 安装依赖
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    python3 \
    python3-pip \
    python3-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 安装Python依赖
RUN pip3 install --no-cache-dir \
    flask==3.1.2 \
    flask-cors==6.0.2 \
    pillow==12.1.1 \
    numpy==2.4.2 \
    requests==2.32.5 \
    gguf==0.17.1

# 编译llama.cpp (CPU版本)
WORKDIR /build
RUN git clone https://github.com/ggerganov/llama.cpp.git
WORKDIR /build/llama.cpp
RUN mkdir build && cd build \
    && cmake .. -DLLAMA_NATIVE=ON -DCMAKE_BUILD_TYPE=Release \
    && cmake --build . --config Release --target llama-diffusion-cli

# 复制可执行文件
RUN cp /build/llama.cpp/build/bin/llama-diffusion-cli /usr/local/bin/

# 设置工作目录
WORKDIR /app

# 复制应用代码
COPY server/llama_cpp_native_image_server.py /app/
COPY server/model_paths.py /app/

# 创建模型目录
RUN mkdir -p /app/models/image_gen/images

# 暴露端口
EXPOSE 5004

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:5004/api/native_llama_cpp_image/health || exit 1

# 启动服务
CMD ["python3", "llama_cpp_native_image_server.py"]